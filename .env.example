# Lattice Privacy Proxy URL (default port 8080)
LATTICE_URL=http://localhost:8080/v1/chat/completions

# LLM model (the proxy redirects to the configured backend)
LLM_MODEL=mistral

# Temperature: 0.0 = deterministic, 1.0 = creative
LLM_TEMPERATURE=0.1

# Conversation history character limit (respects Lattice token vault)
MAX_HISTORY_CHARS=16000

# ─── Business Rules ──────────────────────────────────────────
# PolicyEngine limits are configured in business_rules.yaml
# NOT in this file. Edit business_rules.yaml directly.
