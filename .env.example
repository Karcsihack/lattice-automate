# URL del Lattice Privacy Proxy (puerto 8080 por defecto)
LATTICE_URL=http://localhost:8080/v1/chat/completions

# Modelo LLM (el proxy redirige al backend configurado)
LLM_MODEL=mistral

# Temperatura: 0.0 = determinista, 1.0 = creativo
LLM_TEMPERATURE=0.1

# Límite de historial de conversación en caracteres
MAX_HISTORY_CHARS=16000

# ─── Reglas de Negocio ───────────────────────────────────────
# Los límites del PolicyEngine se configuran en business_rules.yaml
# NO en este archivo. Edita business_rules.yaml directamente.
